{
  "name": "llm-wiki-plugin",
  "version": "1.0.2",
  "description": "Local-first LLM-powered knowledge base for your Obsidian vault",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "node esbuild.config.mjs production",
    "dev": "node esbuild.config.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .ts,.cjs",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "llm",
    "knowledge-base"
  ],
  "author": "Dominique Leca",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^20.11.0",
    "@vitest/coverage-v8": "^1.6.1",
    "builtin-modules": "^4.0.0",
    "esbuild": "^0.20.2",
    "eslint": "^9.39.4",
    "eslint-plugin-obsidianmd": "^0.2.8",
    "fast-check": "^3.17.0",
    "jsdom": "^29.0.2",
    "obsidian": "^1.5.7",
    "tslib": "^2.6.2",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.59.1",
    "vitest": "^1.5.0"
  }
}
